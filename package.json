    "dotenv": "^16.3.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^131.0.0",
    "lucide-react": "^1.7.0",
    "next": "^15.1.0",
    "octokit": "^3.1.2",
    "openai": "^4.24.1",
    "qrcode-terminal": "^0.12.0",
